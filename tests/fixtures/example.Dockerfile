# syntax=docker/dockerfile:1
FROM alpine/openclaw:main
LABEL org.opencontainers.image.title="ops-agent"
LABEL org.opencontainers.image.version="1.2.3"
LABEL io.openclawenv.manifest-hash="292110ecf385f765940d938b6a407f808dd6e4463c31b1d9fbcd0d25263c4531"
LABEL io.openclawenv.sandbox-image="python:3.12-slim@sha256:1111111111111111111111111111111111111111111111111111111111111111"
ENV PYTHONDONTWRITEBYTECODE=1
USER root
ENV OPENCLAWENV_PROJECT="ops-agent"
ENV PYTHONUNBUFFERED="1"
RUN if command -v apt-get >/dev/null 2>&1; then apt-get update && apt-get install -y --no-install-recommends git curl chromium python3 python3-pip bash nodejs npm && rm -rf /var/lib/apt/lists/*; elif command -v apk >/dev/null 2>&1; then apk add --no-cache git curl chromium nodejs npm python3 py3-pip bash; else echo 'Unsupported base image: no apt-get or apk available.' >&2; exit 1; fi
RUN mkdir -p /usr/local/bin && if ! command -v python >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1; then ln -sf "$(command -v python3)" /usr/local/bin/python; fi
RUN mkdir -p /usr/local/bin && if ! command -v pip >/dev/null 2>&1 && command -v pip3 >/dev/null 2>&1; then ln -sf "$(command -v pip3)" /usr/local/bin/pip; fi
RUN if ! command -v npx >/dev/null 2>&1; then printf '%s\n' '#!/bin/sh' 'exec npm exec --yes -- "$@"' > /usr/local/bin/npx && chmod +x /usr/local/bin/npx; fi
RUN python -m pip install --no-cache-dir cisco-ai-skill-scanner==2.0.4 requests==2.32.3 rich==13.9.4
RUN npm install --global --no-fund --no-update-notifier agent-browser typescript@5.8.3
RUN agent-browser install
RUN mkdir -p "/opt/openclaw" /root "/home/node" && ln -sfn "/opt/openclaw" /root/.openclaw && ln -sfn "/opt/openclaw" "/home/node/.openclaw"
RUN if id -u "agent" >/dev/null 2>&1; then mkdir -p "/home/agent" && ln -sfn "/opt/openclaw" "/home/agent/.openclaw"; fi
RUN mkdir -p /opt/openclawenv
RUN ["python", "-c", "import base64, json, pathlib; payload=json.loads(base64.b64decode('').decode('utf-8')); [pathlib.Path(directory).mkdir(parents=True, exist_ok=True) for directory in payload['directories']]; [pathlib.Path(path).write_text(content, encoding='utf-8') for path, content in payload['files'].items()]"]
RUN rm -rf "/opt/openclaw/workspace/skills/free-ride" && npx clawhub@latest install freeride
RUN python -m pip install --no-cache-dir -e "/opt/openclaw/workspace/skills/free-ride"
ARG OPENCLAWENV_SKILL_SCAN_FORMAT=summary
ARG OPENCLAWENV_SKILL_SCAN_POLICY=balanced
ARG OPENCLAWENV_SKILL_SCAN_FAIL_ON_SEVERITY=high
RUN if [ -d "/opt/openclaw/workspace/skills" ] && find "/opt/openclaw/workspace/skills" -mindepth 1 -maxdepth 1 -type d -print -quit | grep -q .; then skill-scanner scan-all "/opt/openclaw/workspace/skills" --recursive --check-overlap --format "$OPENCLAWENV_SKILL_SCAN_FORMAT" --policy "$OPENCLAWENV_SKILL_SCAN_POLICY" --fail-on-severity "$OPENCLAWENV_SKILL_SCAN_FAIL_ON_SEVERITY"; else echo 'No skills to scan; skipping skill-scanner.'; fi
RUN mkdir -p "/workspace" && if id -u "node" >/dev/null 2>&1; then chown -R node:node "/opt/openclaw" "/workspace"; fi
USER node
